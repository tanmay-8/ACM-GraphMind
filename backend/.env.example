# ============================================
# GraphMind Backend Configuration
# ============================================

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# LLM API Keys
# Get Gemini key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Authentication
JWT_SECRET_KEY=your_secret_key_here_change_in_production

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Milvus Configuration - TODO: Uncomment when implementing vector retrieval
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_COLLECTION=financial_memory

# Embedding Configuration - TODO: Uncomment when implementing vector retrieval
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIMENSION=384

# Retrieval Settings
DEFAULT_TOP_K=5
MAX_GRAPH_DEPTH=3

# CORS Settings (comma-separated origins)
CORS_ORIGINS=*